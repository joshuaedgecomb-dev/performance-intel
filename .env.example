# Performance Intel + Corp MBR data source URLs.
# Copy this file to `.env.local` and fill in your published Google Sheet CSV URLs.
# `.env.local` is gitignored — it will NOT be committed.
#
# Each URL should be a "Publish to web" CSV export for the relevant sheet/tab.

# Core Performance Intel sheets
VITE_DEFAULT_AGENT_SHEET_URL=
VITE_DEFAULT_GOALS_SHEET_URL=
VITE_DEFAULT_NH_SHEET_URL=
VITE_DEFAULT_PRIOR_SHEET_URL=
VITE_DEFAULT_PRIOR_GOALS_SHEET_URL=
VITE_DEFAULT_TNPS_SHEET_URL=

# Corp MBR data sources (Slides 2/3/5)
VITE_DEFAULT_CORP_COACHING_DETAILS_URL=
VITE_DEFAULT_CORP_COACHING_WEEKLY_URL=
VITE_DEFAULT_CORP_LOGIN_BUCKETS_URL=
